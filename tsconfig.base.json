{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@flyfree/ui": ["packages/ui/src"],
      "@flyfree/types": ["packages/types/src"],
      "@flyfree/utils": ["packages/utils/src"],
      "@flyfree/config": ["packages/config/src"]
    }
  }
}
