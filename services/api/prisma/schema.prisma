generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomizationStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
  IN_PRODUCTION
  COMPLETED
}

model User {
  id              String                 @id @default(cuid())
  name            String?
  email           String?                @unique
  phone           String?                @unique
  passwordHash    String?
  emailVerified   Boolean                @default(false)
  emailVerifiedAt DateTime?
  image           String?
  addresses       Address[]
  orders          Order[]
  wishlistItems   Wishlist[]
  reviews         Review[]
  customRequests  CustomizationRequest[]
  customDesigns   CustomDesign[]         @relation("CustomDesigns")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model EmailVerification {
  id        String    @id @default(cuid())
  email     String    @unique
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions Permission[]
  admins      AdminUser[]
}

model Permission {
  id     String @id @default(cuid())
  action String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  priority  Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Theme {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?
  story          String?
  imageUrl       String?
  bannerImageUrl String?
  primaryColor   String         @default("#111827")
  secondaryColor String         @default("#ff6b5b")
  accentColor    String         @default("#4ecdc4")
  fontFamily     String         @default("Inter, Arial, sans-serif")
  animationStyle String         @default("fade")
  priority       Int            @default(0)
  active         Boolean        @default(false)
  startsAt       DateTime?
  endsAt         DateTime?
  products       Product[]
  announcements  Announcement[]
}

model Collection {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  priority  Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  sku             String           @unique
  description     String
  gender          Gender           @default(UNISEX)
  tags            String[]
  brand           String           @default("Fly Free")
  material        String?
  washCare        String?
  price           Int
  mrp             Int
  discountPercent Int              @default(0)
  gstPercent      Int              @default(5)
  weightGrams     Int?
  videoUrl        String?
  view360Url      String?
  seoTitle        String?
  seoDescription  String?
  isVisible       Boolean          @default(true)
  isFeatured      Boolean          @default(false)
  isTrending      Boolean          @default(false)
  isNewArrival    Boolean          @default(false)
  categoryId      String
  collectionId    String?
  themeId         String?
  category        Category         @relation(fields: [categoryId], references: [id])
  collection      Collection?      @relation(fields: [collectionId], references: [id])
  theme           Theme?           @relation(fields: [themeId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]
  hampers         ProductHamper[]
  reviews         Review[]
  orderItems      OrderItem[]
  wishlistItems   Wishlist[]
  influencers     Influencer[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  color     String?
  url       String
  alt       String?
  priority  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String     @id @default(cuid())
  productId String
  sku       String     @unique
  color     String
  size      String
  price     Int?
  product   Product    @relation(fields: [productId], references: [id])
  inventory Inventory?
}

model ProductHamper {
  id          String   @id @default(cuid())
  productId   String
  name        String
  description String?
  contents    String[] @default([])
  imageUrl    String?
  images      String[] @default([])
  sizeNote    String?
  price       Int
  gstPercent  Int      @default(5)
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([isActive])
}

model Inventory {
  id            String         @id @default(cuid())
  variantId     String         @unique
  stock         Int            @default(0)
  lowStockAlert Int            @default(5)
  warehouse     String?
  barcode       String?
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  updatedAt     DateTime       @updatedAt
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("India")
  user       User    @relation(fields: [userId], references: [id])
  orders     Order[]
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?
  guestId   String?
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int
  cart      Cart   @relation(fields: [cartId], references: [id])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String?
  guestId   String?
  productId String
  user      User?    @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model Order {
  id                  String               @id @default(cuid())
  userId              String
  shippingAddressId   String
  status              OrderStatus          @default(PLACED)
  subtotal            Int
  discount            Int                  @default(0)
  shippingFee         Int                  @default(0)
  tax                 Int                  @default(0)
  total               Int
  user                User                 @relation(fields: [userId], references: [id])
  shippingAddress     Address              @relation(fields: [shippingAddressId], references: [id])
  items               OrderItem[]
  payment             Payment?
  referrals           Referral[]
  invoice             Invoice?
  statusHistory       OrderStatusHistory[]
  reviews             Review[]
  reviewRequestSentAt DateTime?
  reviewSubmittedAt   DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  note       String?
  changedBy  String?
  order      Order        @relation(fields: [orderId], references: [id])
  createdAt  DateTime     @default(now())
}

model Invoice {
  id            String    @id @default(cuid())
  orderId       String    @unique
  invoiceNumber String    @unique
  status        String    @default("GENERATED")
  sentAt        DateTime?
  metadata      Json?
  order         Order     @relation(fields: [orderId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String
  name      String
  sku       String
  price     Int
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountAmount  Int?
  discountPercent Int?
  minOrderAmount  Int?
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean   @default(true)
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  provider          String        @default("RAZORPAY")
  providerPaymentId String?
  status            PaymentStatus @default(PENDING)
  amount            Int
  rawPayload        Json?
  paidAt            DateTime?
  order             Order         @relation(fields: [orderId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
}

model Review {
  id           String       @id @default(cuid())
  userId       String
  productId    String
  orderId      String?
  rating       Int
  title        String?
  body         String
  mediaUrls    String[]
  helpfulVotes Int          @default(0)
  status       ReviewStatus @default(PENDING)
  user         User         @relation(fields: [userId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  order        Order?       @relation(fields: [orderId], references: [id])
  createdAt    DateTime     @default(now())
}

model Announcement {
  id             String        @id @default(cuid())
  title          String
  message        String
  href           String?
  imageUrl       String?
  ctaLabel       String?
  type           String        @default("INFO")
  priority       Int           @default(0)
  isActive       Boolean       @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  themeId        String?
  theme          Theme?        @relation(fields: [themeId], references: [id])
  websiteThemeId String?
  websiteTheme   WebsiteTheme? @relation(fields: [websiteThemeId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Notification {
  id         String    @id @default(cuid())
  userId     String?
  channel    String
  type       String?
  entityType String?
  entityId   String?
  title      String
  body       String
  status     String    @default("PENDING")
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String
  metaTitle   String?
  metaDesc    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomizationRequest {
  id          String              @id @default(cuid())
  userId      String
  productId   String?
  placement   String
  quantity    Int
  size        String
  color       String
  message     String?
  fileUrls    String[]
  status      CustomizationStatus @default(REQUESTED)
  quotedPrice Int?
  user        User                @relation(fields: [userId], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Influencer {
  id                   String     @id @default(cuid())
  name                 String
  email                String     @unique
  code                 String     @unique
  linkKey              String?
  imageUrl             String?
  instagramUrl         String?
  facebookUrl          String?
  xUrl                 String?
  buyerDiscountPercent Int        @default(10)
  commissionRate       Float      @default(5.0)
  totalEarnings        Int        @default(0)
  totalReferrals       Int        @default(0)
  isActive             Boolean    @default(true)
  socialHandle         String?
  followers            Int?
  productId            String?
  product              Product?   @relation(fields: [productId], references: [id])
  referrals            Referral[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model Referral {
  id                   String     @id @default(cuid())
  influencerId         String
  orderId              String?
  code                 String     @unique
  buyerDiscountPercent Int        @default(0)
  commissionAmount     Int        @default(0)
  linkKey              String?
  convertedAt          DateTime?
  clicks               Int        @default(0)
  conversions          Int        @default(0)
  totalEarnings        Int        @default(0)
  influencer           Influencer @relation(fields: [influencerId], references: [id])
  order                Order?     @relation(fields: [orderId], references: [id])
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model WebsiteTheme {
  id                 String    @id @default(cuid())
  name               String    @unique
  slug               String    @unique
  description        String?
  primaryColor       String
  secondaryColor     String
  backgroundColor    String
  textColor          String
  accentColor        String
  fontFamily         String
  animationStyle     String    @default("fade")
  heroTitle          String?
  heroSubtitle       String?
  heroDesktopImageUrl String?
  heroMobileImageUrl  String?
  heroCtaLabel       String?
  heroHref           String?
  priority           Int       @default(0)
  startsAt           DateTime?
  endsAt             DateTime?
  isActive           Boolean   @default(false)
  announcements      Announcement[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model CustomDesign {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  images      String[] @default([])
  size        String
  color       String
  placement   String
  notes       String?
  status      String   @default("PENDING")
  price       Int?
  user        User     @relation("CustomDesigns", fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Return {
  id           String   @id @default(cuid())
  orderId      String
  reason       String
  description  String?
  status       String   @default("REQUESTED")
  refundAmount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SizeGuide {
  id           String   @id @default(cuid())
  size         String   @unique // S, M, L, XL, XXL
  chest        String   // 44", 46", 48", 51"
  shoulder     String   // 20.5", 21.5", 22.5", 23.5"
  length       String   // 28", 29", 30", 30.5"
  sleeve       String   // 8.5", 9", 9.5", 10"
  priority     Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([size])
  @@index([active])
}

model HeroBanner {
  id               String   @id @default(cuid())
  title            String
  subtitle         String?
  imageUrl         String
  mobileImageUrl   String?
  ctaLabel         String?
  ctaHref          String?
  priority         Int      @default(0)
  isActive         Boolean  @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
}

